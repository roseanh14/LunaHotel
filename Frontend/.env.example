# Copy to .env.development or .env.local
# true  = demo: mock rooms, search, book flow, find-by-code, admin booking list (rich UI for presentations).
#         Login/register/profile still use the real backend when the server runs.
# false = everything from the real API (Spring Boot on VITE_API_URL or default localhost:4040)
VITE_USE_MOCK_DATA=false
